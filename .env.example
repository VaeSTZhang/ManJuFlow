# App config

APP_NAME=Dramora
APP_ENV=local

# Generation modes
# Supported values: mock / llm

SCRIPT_GENERATION_MODE=mock
STORYBOARD_GENERATION_MODE=mock
IMAGE_PROMPT_GENERATION_MODE=mock
ASSISTANT_GENERATION_MODE=mock

# Dramora default LLM selection
# DeepSeek is the recommended internal default, but request-level AIRequestOptions can override provider/model.
# Keep real API keys only in the private root .env file.

DEFAULT_LLM_PROVIDER=deepseek
DEFAULT_SCRIPT_MODEL=deepseek-chat
LLM_REQUEST_TIMEOUT_SECONDS=60

# Image Generation / ComfyUI provider settings
# Current public repository default should stay mock.
# Real ComfyUI values must only be written into private .env files and private deployment environments.

IMAGE_GENERATION_PROVIDER=mock

# The following ComfyUI variables are placeholders only.
# Do not put real server URLs, API tokens, workflow names, model paths, or private storage config in the public repository.

COMFYUI_BASE_URL=
COMFYUI_API_TOKEN=
COMFYUI_WORKFLOW_NAME=
COMFYUI_TIMEOUT_SECONDS=120
COMFYUI_POLL_INTERVAL_SECONDS=2
COMFYUI_OUTPUT_BASE_URL=

# Compatibility LLM provider config.
# Keep these fields for current LLMClient compatibility and OpenAI-compatible fallback.
# DEFAULT_LLM_PROVIDER / DEFAULT_SCRIPT_MODEL are the recommended Dramora default-selection fields.
# Supported provider values: default / deepseek / mimo / kimi / minimax

LLM_PROVIDER=

# Generic OpenAI-compatible fallback config

LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=

# DeepSeek provider config
# Endpoint used by LLMClient: DEEPSEEK_BASE_URL + /v1/chat/completions

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=

# Mimo provider config
# Endpoint used by LLMClient: MIMO_BASE_URL + /v1/chat/completions
# Use sk- API Key for Dramora backend direct API calls.
# tp- Token Plan Key is for coding tools / agent tools and is not used here.

MIMO_BASE_URL=https://api.xiaomimimo.com
MIMO_MODEL=mimo-v2.5-pro
MIMO_API_KEY=

# Kimi provider config
# Endpoint used by LLMClient: KIMI_BASE_URL + /v1/chat/completions
# Kimi k2.x currently requires temperature=1; LLMClient handles this automatically.

KIMI_BASE_URL=https://api.moonshot.cn
KIMI_MODEL=kimi-k2.5
KIMI_API_KEY=

# MiniMax provider config
# Endpoint used by LLMClient: MINIMAX_BASE_URL + /v1/chat/completions
# If using international region, MINIMAX_BASE_URL may be https://api.minimax.io

MINIMAX_BASE_URL=https://api.minimaxi.com
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_API_KEY=

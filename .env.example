# App config

APP_NAME=ManJuFlow
APP_ENV=development

# Generation modes
# Supported values: mock / llm

SCRIPT_GENERATION_MODE=mock
STORYBOARD_GENERATION_MODE=mock
IMAGE_PROMPT_GENERATION_MODE=mock

# Active default LLM provider for backend-side generation.
# This selects the default provider used by LLMClient when a request does not specify a provider.
# All provider credentials below can coexist in .env.
# Future frontend model selection should choose provider/model per request instead of requiring .env edits.
# Supported values: default / deepseek / mimo / kimi / minimax

LLM_PROVIDER=default

# Legacy OpenAI-compatible config
# Used when LLM_PROVIDER=default

LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=

# DeepSeek provider config
# Endpoint used by LLMClient: DEEPSEEK_BASE_URL + /v1/chat/completions

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=

# Mimo provider config
# Endpoint used by LLMClient: MIMO_BASE_URL + /v1/chat/completions
# Use sk- API Key for ManJuFlow backend direct API calls.
# tp- Token Plan Key is for coding tools / agent tools and is not used here.

MIMO_BASE_URL=https://api.xiaomimimo.com
MIMO_MODEL=mimo-v2.5-pro
MIMO_API_KEY=

# Kimi provider config
# Endpoint used by LLMClient: KIMI_BASE_URL + /v1/chat/completions

KIMI_BASE_URL=https://api.moonshot.cn
KIMI_MODEL=kimi-k2.5
KIMI_API_KEY=

# MiniMax provider config
# Endpoint used by LLMClient: MINIMAX_BASE_URL + /v1/chat/completions
# If using China region, MINIMAX_BASE_URL may be https://api.minimaxi.com

MINIMAX_BASE_URL=https://api.minimax.io
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_API_KEY=
